{
  "name": "ayisha-js",
  "version": "1.0.0",
  "description": "Advanced Reactive JavaScript Framework with declarative data binding, component system, and modern features",
  "main": "ayisha.js",
  "scripts": {
    "start": "python -m http.server 5500",
    "test": "echo \"Run tests in browser - open test.html\"",
    "build": "echo \"No build step required - framework is ready to use\"",
    "docs": "echo \"Open README.md for documentation\""
  },
  "keywords": [
    "javascript",
    "framework",
    "reactive",
    "spa",
    "components",
    "data-binding",
    "declarative",
    "vanilla-js"
  ],
  "author": "DevBen",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/devben/ayisha-js"
  },
  "bugs": {
    "url": "https://github.com/devben/ayisha-js/issues"
  },
  "homepage": "https://github.com/devben/ayisha-js#readme",
  "files": [
    "ayisha.js",
    "examples.html",
    "advanced-examples.html",
    "README.md"
  ],
  "engines": {
    "node": ">=12.0.0"
  },
  "ayisha": {
    "features": [
      "reactive-system",
      "component-system",
      "validation",
      "animations",
      "spa-router",
      "plugins",
      "devtools",
      "performance-monitoring",
      "error-handling",
      "ssr-support",
      "testing-utilities"
    ],
    "directives": [
      "@init",
      "@mounted",
      "@text",
      "@model",
      "@class",
      "@style",
      "@if",
      "@show",
      "@hide",
      "@for",
      "@fetch",
      "@validate",
      "@animate",
      "@component",
      "@page",
      "@link",
      "@watch"
    ],
    "modifiers": [
      "prevent",
      "stop",
      "once",
      "enter",
      "debounce",
      "throttle"
    ]
  }
}